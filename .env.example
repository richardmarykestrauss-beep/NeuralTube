# ─── NeuralTube Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── YouTube OAuth ────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID (Web application type)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Obtained after completing the OAuth flow at /api/auth/youtube/url
# Store this securely — it allows uploading to your YouTube channel
YOUTUBE_REFRESH_TOKEN=

# The public URL of this backend (used as OAuth redirect URI)
# e.g. https://neuraltube-backend-xxx.run.app
APP_URL=

# ─── Google AI (Gemini) ───────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
# Used for: script generation, SEO, hooks, humanizer, shorts, title optimizer
GEMINI_API_KEY=

# Optional: override the default model (default: gemini-2.5-flash)
# STRATEGY_AI_MODEL=gemini-2.5-flash

# ─── Google Cloud (Firebase + TTS) ───────────────────────────────────────────
# Service account JSON (stringified) for Firestore and Cloud TTS
# Get from: https://console.cloud.google.com → IAM → Service Accounts
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# ─── SerpAPI (Google Trends) ─────────────────────────────────────────────────
# Get from: https://serpapi.com/dashboard (100 free searches/month)
# Used for: real Google Trends data in TrendScanner
SERP_API_KEY=

# ─── Pexels (Stock Images for Video Assembly) ────────────────────────────────
# Get from: https://www.pexels.com/api/ (free, unlimited)
# Used for: fetching stock images during video assembly
PEXELS_API_KEY=
